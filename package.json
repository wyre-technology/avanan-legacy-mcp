{
  "name": "@wyre-technology/avanan-legacy-mcp",
  "version": "0.0.0",
  "description": "MCP server for the Avanan MSP SmartAPI (legacy Avanan MSP tenant management) - manage child MSPs, MSP users, customer tenants, licenses, and usage.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "avanan-legacy-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyre-technology/avanan-legacy-mcp.git"
  },
  "keywords": [
    "mcp",
    "claude",
    "avanan",
    "checkpoint",
    "msp",
    "smartapi",
    "tenant-management",
    "msp-management"
  ],
  "author": "Wyre Technology",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/wyre-technology/avanan-legacy-mcp/issues"
  },
  "homepage": "https://github.com/wyre-technology/avanan-legacy-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/github": "^10.3.5",
    "@semantic-release/npm": "^12.0.1",
    "@types/node": "^22.10.5",
    "semantic-release": "^24.2.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
