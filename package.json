{
  "name": "@wyre-technology/avanan-legacy-mcp",
  "version": "0.0.0",
  "description": "MCP server for the Avanan MSP SmartAPI (legacy Avanan MSP tenant management) - manage child MSPs, MSP users, customer tenants, licenses, and usage.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "avanan-legacy-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:ui": "vite build && node scripts/embed-ui.mjs",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyre-technology/avanan-legacy-mcp.git"
  },
  "keywords": [
    "mcp",
    "claude",
    "avanan",
    "checkpoint",
    "msp",
    "smartapi",
    "tenant-management",
    "msp-management"
  ],
  "author": "Wyre Technology",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/wyre-technology/avanan-legacy-mcp/issues"
  },
  "homepage": "https://github.com/wyre-technology/avanan-legacy-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/ext-apps": "^1.7.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "semantic-release": "^25.0.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.1.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
